// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  EMPLOYER
  ADMIN
  SUPER_ADMIN
}

enum CompanyMemberRole {
  OWNER
  ADMIN
  RECRUITER
  HIRING_MANAGER
}

enum CompanyMemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LEFT
  REMOVED
  CANCELLED
}

enum CompanyStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanyVisibility {
  PUBLIC
  PRIVATE
}

enum AccountStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  BLOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ExperienceLevel {
  FRESHER
  INTERN
  JUNIOR
  MID_LEVEL
  SENIOR
  LEAD
  ARCHITECT
}

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  FILLED
  EXPIRED
  ARCHIVED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
  TEMPORARY
  APPRENTICESHIP
}

enum WorkplaceType {
  ONSITE
  REMOTE
  HYBRID
}

enum JobVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

enum SalaryPeriod {
  HOURLY
  MONTHLY
  YEARLY
}

enum GradingSystem {
  PERCENTAGE
  CGPA
  GPA_4
  GPA_5
  GPA_10
  LETTER_GRADE
  PASS_FAIL
  OTHER
}

enum ApplicationStatus {
  APPLIED
  INREVIEW
  SCREENING
  SHORTLISTED
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model User {
  id                          String          @id @default(cuid())
  email                       String          @unique
  password                    String
  otp                         String?
  otpExpiresAt                DateTime?
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  role                        UserRole
  status                      AccountStatus   @default(PENDING)
  isEmailVerified             Boolean         @default(false)
  lastLoginAt                 DateTime?
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  deletedAt                   DateTime?
  deletedById                 String?
  deletedBy                   User?           @relation("DeletedBy", fields: [deletedById], references: [id])
  deletedUsers                User[]          @relation("DeletedBy")
  suspendedAt                 DateTime?
  suspendedById               String?
  suspendedBy                 User?           @relation("SuspendedBy", fields: [suspendedById], references: [id])
  suspendedUsers              User[]          @relation("SuspendedBy")
  suspendedReason             String?
  restoredAt                  DateTime?
  restoredById                String?
  restoredBy                  User?           @relation("RestoredBy", fields: [restoredById], references: [id])
  restoredUsers               User[]          @relation("RestoredBy")
  refreshTokens               RefreshToken[]
  candidate                   Candidate?
  employer                    Employer?
  admin                       Admin?
  companyMemberships          CompanyMember[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Candidate {
  id                 String                @id @default(cuid())
  userId             String                @unique
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  phoneNumber        String?
  profilePicture     String?
  headline           String?
  bio                String?
  dateOfBirth        DateTime?
  gender             Gender?
  experienceLevel    ExperienceLevel?
  currentLocation    String?
  preferredLocation  String?
  currentCompany     String?
  currentDesignation String?
  totalExperience    Float?
  expectedSalary     Int?
  currentSalary      Int?
  noticePeriod       Int?
  linkedinUrl        String?
  githubUrl          String?
  portfolioUrl       String?
  websiteUrl         String?
  isOpenToWork       Boolean               @default(true)
  profileCompletion  Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  skills             CandidateSkill[]
  educations         CandidateEducation[]
  experiences        CandidateExperience[]
  resumes            Resume[]
  applications       Application[]

  @@index([experienceLevel])
  @@index([currentLocation])
  @@index([isOpenToWork])
}

model Employer {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  phoneNumber    String?
  designation    String?
  department     String?
  profilePicture String?
  linkedinUrl    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Company {
  id                String            @id @default(cuid())
  companyName       String
  slug              String            @unique
  companyEmail      String?
  phoneNumber       String?
  website           String?
  logo              String?
  coverImage        String?
  description       String?
  industry          String?
  companySize       String?
  foundedYear       Int?
  headquarters      String?
  linkedinUrl       String?
  twitterUrl        String?
  status            CompanyStatus     @default(DRAFT)
  visibility        CompanyVisibility @default(PUBLIC)
  profileCompletion Int               @default(0)
  isVerified        Boolean           @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  deletedBy         String?
  suspendedAt       DateTime?
  suspendedBy       String?
  suspendedReason   String?
  restoredAt        DateTime?
  restoredBy        String?
  jobs              Job[]
  companyMembers    CompanyMember[]
}

model CompanyMember {
  id              String              @id @default(cuid())
  userId          String
  companyId       String
  role            CompanyMemberRole
  joinedAt        DateTime            @default(now())
  status          CompanyMemberStatus @default(ACTIVE)
  invitationToken String?             @unique
  invitedAt       DateTime?
  expiresAt       DateTime?
  invitedBy       String?
  user            User                @relation(fields: [userId], references: [id])
  company         Company             @relation(fields: [companyId], references: [id])
  jobMembers      JobMember[]

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model Admin {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  phoneNumber    String?
  profilePicture String?
  designation    String?
  department     String?
  employeeId     String?   @unique
  isSuperAdmin   Boolean   @default(false)
  isActive       Boolean   @default(true)
  lastActiveAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Job {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  title String
  slug  String @unique

  summary     String?
  description String

  employmentType EmploymentType
  workplaceType  WorkplaceType

  status     JobStatus     @default(DRAFT)
  visibility JobVisibility @default(PUBLIC)

  vacancies Int @default(1)

  location String?

  minExperience Int @default(0)
  maxExperience Int @default(0)

  minimumSalary Int?
  maximumSalary Int?
  salaryPeriod  SalaryPeriod?
  hideSalary    Boolean       @default(false)

  applicationDeadline DateTime?

  publishedAt DateTime?
  closedAt    DateTime?
  archivedAt  DateTime?

  createdById String
  updatedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills       JobSkill[]
  benefits     JobBenefit[]
  members      JobMember[]
  applications Application[]

  @@index([companyId])
  @@index([status])
  @@index([employmentType])
  @@index([workplaceType])
}

model JobSkill {
  id String @id @default(cuid())

  name String

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  isRequired Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, name])
  @@index([jobId])
}

model JobBenefit {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  benefit String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, benefit])
  @@index([jobId])
}

model JobMember {
  id String @id @default(cuid())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String?

  companyMemberId String
  companyMember   CompanyMember @relation(fields: [companyMemberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, companyMemberId])
  @@index([jobId])
  @@index([companyMemberId])
}

model Application {
  id String @id @default(cuid())

  candidateId String
  jobId       String
  resumeId    String

  status ApplicationStatus @default(APPLIED)

  coverLetter String?

  appliedAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastStatusUpdatedAt DateTime?

  withdrawnAt    DateTime?
  withdrawReason String?

  rejectedAt      DateTime?
  rejectionReason String?

  hiredAt DateTime?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume    Resume    @relation(fields: [resumeId], references: [id])

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([jobId, status])
}

model Resume {
  id          String    @id @default(cuid())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId String
  resumeName  String
  resumeUrl   String
  fileSize    Int
  uploadedAt  DateTime  @default(now())
  deletedAt   DateTime?

  applications Application[]

  @@index([candidateId])
}

model CandidateSkill {
  id                String    @id @default(cuid())
  candidateId       String
  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name              String
  yearsOfExperience Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([candidateId, name])
  @@index([candidateId])
}

model CandidateEducation {
  id                String        @id @default(cuid())
  candidate         Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId       String
  collegeName       String
  degree            String
  fieldOfStudy      String
  currentlyStudying Boolean       @default(false)
  startDate         DateTime
  endDate           DateTime?
  gradingSystem     GradingSystem
  gradeText         String?
  grade             Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([candidateId])
}

model CandidateExperience {
  id               String         @id @default(cuid())
  candidate        Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId      String
  companyName      String
  designation      String
  employmentType   EmploymentType
  description      String?
  location         String?
  startDate        DateTime
  endDate          DateTime?
  currentlyWorking Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([candidateId])
  @@index([companyName])
}
